---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: "website" | "article";
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  ogImage,
  ogType = "website",
  structuredData,
} = Astro.props;
const canonical = new URL(
  Astro.url.pathname,
  Astro.site ?? "https://viruchith.com",
);
const resolvedOgImage = new URL(
  ogImage ?? "/logo.png",
  Astro.site ?? "https://viruchith.com",
).toString();
const structuredDataItems = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Viruchith Ganesan, Java backend developer, Spring Boot consultant, microservices architect, GCP, Kubernetes, RabbitMQ, API modernization"
    />
    <meta name="author" content="Viruchith Ganesan" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />

    <meta name="theme-color" content="#0b1326" />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="viruchith.com" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta
      property="og:image:alt"
      content="Viruchith Ganesan portfolio preview"
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <title>{title}</title>
    {
      [
        {
          "@context": "https://schema.org",
          "@type": "Person",
          name: "Viruchith Ganesan",
          url: "https://viruchith.com",
          email: "contact@viruchith.com",
          jobTitle: "Software Development Engineer",
          knowsAbout: [
            "Java",
            "Spring Boot",
            "Microservices",
            "Google Cloud Platform",
            "Kubernetes",
            "REST APIs",
          ],
          alumniOf: {
            "@type": "CollegeOrUniversity",
            name: "Sona College of Technology",
          },
          worksFor: {
            "@type": "Organization",
            name: "Lumen Technologies",
          },
        },
        {
          "@context": "https://schema.org",
          "@type": "ProfessionalService",
          name: "Viruchith Ganesan — Java & Microservices Consultancy",
          url: "https://viruchith.com",
          description:
            "Backend engineering, Spring Boot modernization, cloud-native microservices on GCP, and API platform ownership.",
          areaServed: "Worldwide",
          serviceType: [
            "Java backend development",
            "Spring Boot modernization",
            "Microservices architecture",
            "GCP and Kubernetes deployment",
          ],
          provider: {
            "@type": "Person",
            name: "Viruchith Ganesan",
          },
        },
        ...structuredDataItems,
      ].map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        var win = w;
        win[l] = win[l] || [];
        win[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0] as HTMLScriptElement,
          j = d.createElement(s) as HTMLScriptElement,
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        if (f.parentNode) {
          f.parentNode.insertBefore(j, f);
        }
      })(
        window as Window &
          typeof globalThis &
          Record<string, Array<Record<string, unknown>>>,
        document,
        "script",
        "dataLayer",
        "GTM-WFS47GTS",
      );
    </script>
    <!-- End Google Tag Manager -->
  </head>
  <body class="min-h-screen bg-background text-on-background">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-WFS47GTS"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <slot />
  </body>
</html>
