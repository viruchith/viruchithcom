---
import { Terminal, ArrowRight } from '@lucide/astro';
---

<section class="relative mb-32 flex min-h-[min(716px,90vh)] flex-col justify-center px-6 pt-32 md:px-12 lg:px-24">
  <div
    class="pointer-events-none absolute right-0 top-0 -z-10 h-[500px] w-[500px] rounded-full bg-blue-500/10 blur-[120px] dark:bg-primary/5"
    aria-hidden="true"
  >
  </div>

  <p
    class="font-label text-label-md mb-6 flex items-center gap-2 uppercase tracking-[0.1em] text-blue-600 dark:text-primary"
  >
    <Terminal class="h-4 w-4 shrink-0" stroke-width={1.5} aria-hidden="true" />
    System Architect &amp; Engineer
  </p>

  <h1
    class="font-headline mb-8 max-w-5xl text-5xl font-extrabold leading-[1.1] tracking-tight text-slate-900 dark:text-white md:text-7xl lg:text-8xl"
  >
    <span data-typewriter data-full-text="Viruchith Ganesan">Viruchith Ganesan</span>
  </h1>

  <p class="font-body mb-12 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-on-surface-variant md:text-xl">
    Software Development Engineer specializing in cloud-native applications and scalable architectures. Java, Spring
    Boot, and GCP-backed microservices—with production observability and message-driven pipelines you can run at
    volume.
  </p>

  <div class="flex flex-wrap gap-6">
    <a
      class="stitch-gradient-hero group inline-flex items-center gap-3 rounded-lg px-8 py-4 text-sm font-medium transition-opacity hover:opacity-90"
      href="#projects"
    >
      View My Work
      <ArrowRight class="h-5 w-5 transition-transform group-hover:translate-x-1" stroke-width={1.5} aria-hidden="true" />
    </a>
    <a
      class="inline-flex items-center gap-3 rounded-lg border border-slate-200 bg-white px-8 py-4 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-50 dark:border-outline-variant/20 dark:bg-surface-container-highest dark:text-white dark:hover:bg-surface-container-high"
      href="#contact"
    >
      Contact Me
    </a>
  </div>
</section>

<style>
  [data-typewriter].is-typing {
    border-right: 0.08em solid currentColor;
    padding-right: 0.08em;
    animation: hero-caret-blink 0.9s step-end infinite;
  }

  @keyframes hero-caret-blink {
    from,
    to {
      border-right-color: transparent;
    }
    50% {
      border-right-color: currentColor;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-typewriter].is-typing {
      animation: none;
      border-right: 0;
      padding-right: 0;
    }
  }
</style>

<script>
  function initHeroTypewriter() {
    var el = document.querySelector<HTMLElement>('[data-typewriter]');
    if (!el || el.dataset.loopBound === '1') return;
    var target = el;
    target.dataset.loopBound = '1';

    var text = target.dataset.fullText || '';
    if (!text) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      target.textContent = text;
      return;
    }

    target.classList.add('is-typing');
    var typeSpeed = 85;
    var eraseSpeed = 45;
    var holdDelay = 2000;
    var restartDelay = 500;
    var i = 0;
    var deleting = false;
    var timer: number | null = null;

    function schedule(nextDelay: number) {
      timer = window.setTimeout(function () {
        timer = null;
        tick();
      }, nextDelay);
    }

    function tick() {
      if (document.hidden) return;

      if (!deleting) {
        i += 1;
        target.textContent = text.slice(0, i);
        if (i >= text.length) {
          deleting = true;
          schedule(holdDelay);
          return;
        }
        schedule(typeSpeed);
        return;
      }

      i -= 1;
      target.textContent = text.slice(0, i);
      if (i <= 0) {
        deleting = false;
        schedule(restartDelay);
        return;
      }
      schedule(eraseSpeed);
    }

    document.addEventListener('visibilitychange', function () {
      if (!document.hidden && timer === null) tick();
    });

    target.textContent = '';
    tick();
  }

  initHeroTypewriter();
  document.addEventListener('astro:after-swap', initHeroTypewriter);
</script>
