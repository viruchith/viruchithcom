---
import { GraduationCap, BadgeCheck, Cloud } from '@lucide/astro';
---

<section id="education" class="mb-40 px-6 md:px-12 lg:px-24">
  <div
    class="mb-16 flex items-end justify-between border-b border-surface-container-low pb-8 transition-colors"
  >
    <div>
      <h2 class="font-headline mb-2 text-3xl font-bold text-on-background md:text-4xl">Foundation</h2>
      <p class="font-body text-on-surface-variant">Education and credentials.</p>
    </div>
    <GraduationCap class="h-10 w-10 shrink-0 text-primary opacity-50 md:h-11 md:w-11" stroke-width={1.25} aria-hidden="true" />
  </div>

  <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
    <div
      class="rounded-2xl border border-outline-variant/15 bg-surface-container-low p-8 transition-colors hover:border-outline-variant/20"
    >
      <div class="mb-6 flex items-center gap-4">
        <GraduationCap class="h-8 w-8 text-primary" stroke-width={1.5} aria-hidden="true" />
        <h3 class="font-headline text-xl font-bold text-on-background">Academic degree</h3>
      </div>
      <h4 class="mb-1 text-lg font-bold text-on-background">Bachelor of Computer Science and Engineering</h4>
      <p class="mb-4 font-medium text-primary">Sona College of Technology — Salem, Tamil Nadu</p>
      <p class="font-body text-sm text-on-surface-variant">2019 – 2023 · GPA: 8.85 / 10</p>
      <p class="font-label mt-4 text-xs uppercase tracking-wider text-on-surface-variant/70">Completed</p>
    </div>

    <div
      class="rounded-2xl border border-outline-variant/15 bg-surface-container-low p-8 transition-colors hover:border-outline-variant/20"
    >
      <div class="mb-6 flex items-center gap-4">
        <BadgeCheck class="h-8 w-8 text-primary" stroke-width={1.5} aria-hidden="true" />
        <h3 class="font-headline text-xl font-bold text-on-background">Certifications</h3>
      </div>
      <div class="space-y-6">
        <div class="flex gap-4">
          <div
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded border border-outline-variant/20 bg-surface-container-lowest"
          >
            <Cloud class="h-5 w-5 text-primary" stroke-width={1.5} aria-hidden="true" />
          </div>
          <div>
            <h4 class="mb-1 font-bold text-on-background">Google Cloud Certified – Associate Cloud Engineer</h4>
            <p class="text-sm text-on-surface-variant">February 2024</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded border border-outline-variant/20 bg-surface-container-lowest"
          >
            <Cloud class="h-5 w-5 text-primary" stroke-width={1.5} aria-hidden="true" />
          </div>
          <div>
            <h4 class="mb-1 font-bold text-on-background">Microsoft Azure Fundamentals (AZ-900)</h4>
            <p class="text-sm text-on-surface-variant">February 2021</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded border border-outline-variant/20 bg-surface-container-lowest"
          >
            <Cloud class="h-5 w-5 text-primary" stroke-width={1.5} aria-hidden="true" />
          </div>
          <div>
            <h4 class="mb-1 font-bold text-on-background">Cisco Enterprise Networking, Security &amp; Automation</h4>
            <p class="text-sm text-on-surface-variant">March 2021</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
