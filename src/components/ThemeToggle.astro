---
import { Moon, Sun } from '@lucide/astro';

const STORAGE_KEY = 'viruchith-theme';
---

<button
  type="button"
  class="theme-toggle-btn flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-slate-600 transition-colors duration-500 ease-out hover:bg-slate-100 hover:text-slate-900 dark:text-gray-400 dark:hover:bg-white/5 dark:hover:text-white"
  aria-label="Toggle color theme"
  data-theme-toggle
>
  <span class="hidden dark:inline"><Sun class="h-5 w-5" stroke-width={1.5} aria-hidden="true" /></span>
  <span class="inline dark:hidden"><Moon class="h-5 w-5" stroke-width={1.5} aria-hidden="true" /></span>
</button>

<script define:vars={{ STORAGE_KEY }}>
  function bind() {
    document.querySelectorAll('[data-theme-toggle]').forEach(function (btn) {
      if (btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', function () {
        var root = document.documentElement;
        var persist = function () {
          try {
            localStorage.setItem(STORAGE_KEY, root.classList.contains('dark') ? 'dark' : 'light');
          } catch (e) {}
        };
        var flip = function () {
          root.classList.toggle('dark');
          persist();
        };
        if (typeof document.startViewTransition === 'function') {
          document.startViewTransition(flip);
        } else {
          flip();
        }
      });
    });

    if (!window.__viruchithThemeMqBound) {
      window.__viruchithThemeMqBound = true;
      var mq = window.matchMedia('(prefers-color-scheme: dark)');
      mq.addEventListener('change', function (e) {
        try {
          if (localStorage.getItem(STORAGE_KEY)) return;
        } catch (err) {}
        document.documentElement.classList.toggle('dark', e.matches);
      });
    }
  }

  bind();
  document.addEventListener('astro:after-swap', bind);
</script>
