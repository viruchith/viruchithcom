---
import { Rocket, ExternalLink, LockKeyhole } from "@lucide/astro";

const projects = [
  {
    title: "CloudLab Orchestrator",
    desc: "Web platform for YAML-defined lab environments with plans for browser-based SSH, VNC, and RDP—cloud-native, horizontally scalable, and security-conscious.",
    tags: ["GCP", "Kubernetes", "Spring Boot", "K3s", "Longhorn"],
    link: "",
  },
  {
    title: "IT Ticketing Queuing System",
    desc: "Smart ticketing with auto-bucket routing powered by Ollama-based inference—faster triage and better queue discipline.",
    tags: ["Java", "Spring Boot", "AI routing"],
    link: "",
  },
  {
    title: "Confidentiality Safeguard",
    desc: "Protects confidential web data from malicious extensions using Shadow DOM isolation and vault-style secret handling.",
    tags: ["Security", "Browser", "Shadow DOM"],
    link: "https://github.com/viruchith/SentinelExtension",
  },
  {
    title: "Android Shredder",
    desc: "Android Shredder is a high-security Android application designed to permanently and irrecoverably delete files and directories.",
    tags: ["Android", "Kotlin", "Security","Shredding Algorithms"],
    link: "https://github.com/viruchith/AndroidShredder",
  },
  {
    title: "Beaver Expense Tracker",
    desc: "Beaver Expense Tracker is a responsive web application for managing construction expenses across sites, categories, and timelines. It is built for day-to-day project accounting tasks such as entry, filtering, reporting, receipt management, and export.",
    tags: ["Vite", "React", "Typescript", "Firebase"],
    link: "https://github.com/viruchith/BeaverExpense",
  },
];
---

<section id="projects" class="mb-40 px-6 md:px-12 lg:px-24">
  <div
    class="mb-16 flex items-end justify-between border-b border-surface-container-low pb-8 transition-colors"
  >
    <div>
      <h2
        class="font-headline mb-2 text-3xl font-bold text-on-background md:text-4xl"
      >
        Deployed Architecture
      </h2>
      <p class="font-body text-on-surface-variant">
        Selected systems and solutions.
      </p>
    </div>
    <Rocket
      class="h-10 w-10 shrink-0 text-primary opacity-50 md:h-11 md:w-11"
      stroke-width={1.25}
      aria-hidden="true"
    />
  </div>

  <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
    {
      projects.map((p) => (
        <article class="group relative overflow-hidden rounded-2xl border border-outline-variant/15 bg-surface-container-low transition-colors">
          <div
            class="pointer-events-none absolute inset-0 opacity-40 mix-blend-luminosity transition-opacity duration-700 group-hover:opacity-60"
            aria-hidden="true"
          />
          <div class="relative z-10 p-8">
            <h3 class="font-headline mb-3 text-2xl font-bold text-on-background transition-colors group-hover:text-primary">
              {p.title}
            </h3>
            <p class="font-body mb-6 line-clamp-4 text-on-surface-variant">
              {p.desc}
            </p>
            <div class="mb-8 flex flex-wrap gap-2">
              {p.tags.map((t) => (
                <span class="font-label rounded border border-outline-variant/20 bg-surface-container-lowest px-2 py-1 text-xs text-on-surface-variant transition-colors">
                  {t}
                </span>
              ))}
            </div>
            {p.link ? (
              <span class="inline-flex items-center gap-2 font-medium text-primary opacity-70">
                <a
                  class="inline-flex"
                  href={p.link}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <span>goto</span>&nbsp;
                  <ExternalLink stroke-width={1.5} aria-hidden="true" />
                </a>
              </span>
            ) : (
              <span class="inline-flex items-center font-medium text-on-surface-variant opacity-70">
                Private&nbsp;
                <LockKeyhole stroke-width={1.5} aria-hidden="true" />
              </span>
            )}
          </div>
        </article>
      ))
    }
  </div>
</section>
