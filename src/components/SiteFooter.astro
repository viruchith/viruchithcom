---
import { Mail } from '@lucide/astro';
import BrandGithub from './icons/BrandGithub.astro';
import BrandLinkedin from './icons/BrandLinkedin.astro';
import BrandX from './icons/BrandX.astro';

const year = new Date().getFullYear();

const linkClass =
  'group inline-flex items-center gap-2.5 rounded-lg px-3 py-2 font-body text-sm tracking-wide text-slate-600 transition-colors duration-500 ease-out hover:bg-slate-200/80 hover:text-slate-900 dark:text-gray-400 dark:hover:bg-white/10 dark:hover:text-primary';

const emailClass =
  'group inline-flex items-center gap-2.5 rounded-lg px-3 py-2 font-body text-sm tracking-wide text-blue-600 transition-colors duration-500 ease-out hover:bg-slate-200/80 hover:text-blue-800 dark:text-primary-container dark:hover:bg-white/10 dark:hover:text-primary';
---

<footer
  id="contact"
  class="w-full border-t border-slate-200 bg-slate-50 px-8 py-12 transition-[background-color,border-color] duration-500 ease-out dark:border-outline-variant/10 dark:bg-[#131313] dark:bg-gradient-to-t dark:from-[#1c1b1b] dark:to-transparent"
>
  <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-8 md:flex-row md:gap-6">
    <div class="font-headline text-lg font-bold tracking-tight text-slate-900 transition-colors duration-500 ease-out dark:text-white">
      VIRUCHITH.COM
    </div>

    <nav class="flex flex-wrap items-center justify-center gap-2 md:gap-1" aria-label="Contact and social">
      <a class={linkClass} href="https://github.com/viruchith" rel="noopener noreferrer" target="_blank">
        <BrandGithub class="h-5 w-5 shrink-0 opacity-90 transition-colors duration-500 group-hover:opacity-100" />
        <span>GitHub</span>
      </a>
      <a class={linkClass} href="https://www.linkedin.com/in/viruchith/" rel="noopener noreferrer" target="_blank">
        <BrandLinkedin class="h-5 w-5 shrink-0 opacity-90 transition-colors duration-500 group-hover:opacity-100" />
        <span>LinkedIn</span>
      </a>
      <a class={linkClass} href="https://x.com/viruchith" rel="noopener noreferrer" target="_blank">
        <BrandX class="h-5 w-5 shrink-0 opacity-90 transition-colors duration-500 group-hover:opacity-100" />
        <span>X</span>
      </a>
      <a class={emailClass} href="mailto:contact@viruchith.com">
        <Mail class="h-5 w-5 shrink-0 opacity-90 transition-colors duration-500 group-hover:opacity-100" stroke-width={1.75} aria-hidden="true" />
        <span>Email</span>
      </a>
    </nav>

    <p
      class="font-body text-center text-sm tracking-wide text-slate-500 transition-colors duration-500 ease-out dark:text-gray-500"
    >
      © {year} Viruchith Ganesan. Built with precision.
    </p>
  </div>
</footer>
