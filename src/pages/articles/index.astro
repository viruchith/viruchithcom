---
import { ChevronLeft, ChevronRight } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getAllBlogPosts, mapBlogPost } from '../../lib/blog';

const posts = (await getAllBlogPosts()).map(mapBlogPost);
const title = 'Articles | Viruchith Ganesan';
const description =
  'Technical writing on architecture, platform engineering, cloud-native delivery, observability, and resilient backend systems.';
const pageSize = 6;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: 'https://viruchith.com/articles/',
  isPartOf: {
    '@type': 'WebSite',
    name: 'viruchith.com',
    url: 'https://viruchith.com',
  },
};
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <a href="#main" class="skip-to-content">Skip to content</a>
  <SiteHeader />

  <main id="main" class="relative overflow-hidden px-6 pb-24 pt-32 md:px-12 md:pt-36 lg:px-24">
    <div class="absolute inset-x-0 top-0 -z-10 h-[34rem] bg-[radial-gradient(circle_at_10%_15%,rgba(0,240,255,0.15),transparent_30%),radial-gradient(circle_at_85%_10%,rgba(49,49,192,0.18),transparent_28%),radial-gradient(circle_at_55%_100%,rgba(105,0,179,0.14),transparent_34%)] blur-3xl"></div>

    <section class="mx-auto max-w-screen-2xl border-b border-outline-variant/15 pb-12">
      <div class="max-w-3xl">
        <p class="mb-4 font-mono text-sm uppercase tracking-[0.28em] text-primary-container">The Repository</p>
        <h1 class="font-headline text-5xl font-extrabold tracking-[-0.05em] text-on-background sm:text-6xl lg:text-8xl">
          Technical Insights
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-on-surface-variant">
          Architectural deep-dives, delivery patterns, and systems thinking for cloud-native teams that care about operational quality.
        </p>
      </div>
    </section>

    <section class="mx-auto mt-16 max-w-screen-2xl">
      <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3" data-articles-grid>
        {
          posts.map((post: (typeof posts)[number], index: number) => (
            <div data-article-item>
              <ArticleCard post={post} priority={index === 0} />
            </div>
          ))
        }
      </div>

      <div class="mt-12 hidden items-center justify-between gap-4" data-articles-pagination>
        <button type="button" class="carousel-button" data-page-prev aria-label="Previous page">
          <ChevronLeft class="h-5 w-5" stroke-width={1.8} aria-hidden="true" />
        </button>

        <div class="flex flex-wrap items-center justify-center gap-2" data-page-list></div>

        <button type="button" class="carousel-button" data-page-next aria-label="Next page">
          <ChevronRight class="h-5 w-5" stroke-width={1.8} aria-hidden="true" />
        </button>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<script define:vars={{ pageSize }}>
  function initArticlesPagination() {
    const pagination = document.querySelector('[data-articles-pagination]');
    const pageList = document.querySelector('[data-page-list]');
    const prevButton = document.querySelector('[data-page-prev]');
    const nextButton = document.querySelector('[data-page-next]');
    const articleItems = Array.from(document.querySelectorAll('[data-article-item]'));

    if (!pagination || !pageList || !prevButton || !nextButton || articleItems.length === 0) return;

    const pageSizeValue = Number(pageSize) || 6;
    let currentPage = Math.max(1, Number(new URLSearchParams(window.location.search).get('page') || '1') || 1);

    function writePageToUrl(page) {
      const params = new URLSearchParams(window.location.search);
      if (page > 1) { params.set('page', String(page)); } else { params.delete('page'); }
      window.history.replaceState({}, '', window.location.pathname + (params.toString() ? '?' + params.toString() : ''));
    }

    function renderPagination(totalPages) {
      pageList.innerHTML = '';
      prevButton.disabled = currentPage <= 1;
      nextButton.disabled = currentPage >= totalPages;
      prevButton.classList.toggle('opacity-40', prevButton.disabled);
      nextButton.classList.toggle('opacity-40', nextButton.disabled);

      for (var page = 1; page <= totalPages; page++) {
        var button = document.createElement('button');
        button.type = 'button';
        button.dataset.page = String(page);
        button.textContent = String(page);
        button.className = page === currentPage
          ? 'inline-flex h-11 min-w-11 items-center justify-center rounded-full border border-primary-container/40 bg-primary-container/15 px-4 text-sm font-semibold text-primary'
          : 'inline-flex h-11 min-w-11 items-center justify-center rounded-full border border-outline-variant/20 bg-surface-variant/30 px-4 text-sm font-semibold text-on-surface transition hover:border-primary-container/35 hover:text-primary-container';
        button.setAttribute('aria-label', 'Go to page ' + page);
        if (page === currentPage) button.setAttribute('aria-current', 'page');
        pageList.appendChild(button);
      }

      pagination.classList.toggle('hidden', totalPages <= 1);
      pagination.classList.toggle('flex', totalPages > 1);
    }

    function render() {
      var totalPages = Math.max(1, Math.ceil(articleItems.length / pageSizeValue));
      if (currentPage > totalPages) currentPage = totalPages;
      var start = (currentPage - 1) * pageSizeValue;
      var end = start + pageSizeValue;
      articleItems.forEach(function(item, i) { item.classList.toggle('hidden', i < start || i >= end); });
      renderPagination(totalPages);
      writePageToUrl(currentPage);
    }

    pagination.addEventListener('click', function(event) {
      var target = event.target;
      if (!(target instanceof HTMLElement)) return;
      var pageButton = target.closest('[data-page]');
      if (pageButton && pageButton.dataset.page) { currentPage = Number(pageButton.dataset.page); render(); return; }
      if (target.closest('[data-page-prev]') && currentPage > 1) { currentPage--; render(); return; }
      if (target.closest('[data-page-next]')) { currentPage++; render(); }
    });

    render();
  }

  initArticlesPagination();
  document.addEventListener('astro:after-swap', initArticlesPagination);
</script>