---
import { ChevronLeft, ChevronRight } from '@lucide/astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getAllBlogPosts, mapBlogPost } from '../../../lib/blog';

export async function getStaticPaths() {
  const PAGE_SIZE = 6;
  const posts = await getAllBlogPosts();
  const totalPages = Math.ceil(posts.length / PAGE_SIZE);
  
  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 2) }, // pages 2 onwards; page 1 is /articles/
  }));
}

const PAGE_SIZE = 6;
const allPosts = (await getAllBlogPosts())
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .map(mapBlogPost);

const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const pageNum = parseInt(Astro.params.page || '1', 10);

// Validate page number
if (isNaN(pageNum) || pageNum < 2 || pageNum > totalPages) {
  return Astro.redirect('/articles/');
}

const start = (pageNum - 1) * PAGE_SIZE;
const end = start + PAGE_SIZE;
const posts = allPosts.slice(start, end);

const title = `Articles - Page ${pageNum} | Viruchith Ganesan`;
const description = 'Technical writing on architecture, platform engineering, cloud-native delivery, observability, and resilient backend systems.';

const baseUrl = 'https://viruchith.com/articles/';
const canonicalUrl = pageNum === 1 ? baseUrl : `${baseUrl}page/${pageNum}/`;
const prevUrl = pageNum > 2 ? `${baseUrl}page/${pageNum - 1}/` : (pageNum === 2 ? baseUrl : undefined);
const nextUrl = pageNum < totalPages ? `${baseUrl}page/${pageNum + 1}/` : undefined;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: canonicalUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: 'viruchith.com',
    url: 'https://viruchith.com',
  },
};
---

<BaseLayout 
  title={title} 
  description={description} 
  structuredData={structuredData}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
  </Fragment>

  <a href="#main" class="skip-to-content">Skip to content</a>
  <SiteHeader />

  <main id="main" class="relative overflow-hidden px-6 pb-24 pt-32 md:px-12 md:pt-36 lg:px-24">
    <div class="absolute inset-x-0 top-0 -z-10 h-[34rem] bg-[radial-gradient(circle_at_10%_15%,rgba(0,240,255,0.15),transparent_30%),radial-gradient(circle_at_85%_10%,rgba(49,49,192,0.18),transparent_28%),radial-gradient(circle_at_55%_100%,rgba(105,0,179,0.14),transparent_34%)] blur-3xl"></div>

    <section class="mx-auto max-w-screen-2xl border-b border-outline-variant/15 pb-12">
      <div class="max-w-3xl">
        <p class="mb-4 font-mono text-sm uppercase tracking-[0.28em] text-primary-container">The Repository</p>
        <h1 class="font-headline text-5xl font-extrabold tracking-[-0.05em] text-on-background sm:text-6xl lg:text-8xl">
          Technical Insights
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-on-surface-variant">
          Architectural deep-dives, delivery patterns, and systems thinking for cloud-native teams that care about operational quality.
        </p>
      </div>
    </section>

    <section class="mx-auto mt-16 max-w-screen-2xl">
      <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
        {
          posts.map((post, index) => (
            <ArticleCard post={post} priority={index === 0} />
          ))
        }
      </div>

      {totalPages > 1 && (
        <nav 
          class="mt-12 flex items-center justify-between gap-4" 
          aria-label="Pagination"
        >
          <a 
            href={prevUrl || '#'}
            rel={prevUrl ? 'prev' : undefined}
            class={`inline-flex items-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] transition ${
              prevUrl
                ? 'border-outline-variant/20 text-on-surface hover:border-primary-container/35 hover:text-primary-container'
                : 'pointer-events-none border-outline-variant/10 text-on-surface/40'
            }`}
            aria-disabled={!prevUrl}
          >
            <ChevronLeft class="h-5 w-5" stroke-width={1.8} aria-hidden="true" />
            <span>Previous</span>
          </a>

          <div class="flex flex-wrap items-center justify-center gap-2">
            {Array.from({ length: totalPages }, (_, i) => {
              const page = i + 1;
              const url = page === 1 ? '/articles/' : `/articles/page/${page}/`;
              const isCurrentPage = page === pageNum;
              
              return (
                <a
                  href={url}
                  class={`inline-flex h-11 min-w-11 items-center justify-center rounded-full border px-4 text-sm font-semibold ${
                    isCurrentPage
                      ? 'border-primary-container/40 bg-primary-container/15 text-primary'
                      : 'border-outline-variant/20 bg-surface-variant/30 text-on-surface transition hover:border-primary-container/35 hover:text-primary-container'
                  }`}
                  aria-label={`Go to page ${page}`}
                  aria-current={isCurrentPage ? 'page' : undefined}
                >
                  {page}
                </a>
              );
            })}
          </div>

          <a 
            href={nextUrl || '#'}
            rel={nextUrl ? 'next' : undefined}
            class={`inline-flex items-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] transition ${
              nextUrl
                ? 'border-outline-variant/20 text-on-surface hover:border-primary-container/35 hover:text-primary-container'
                : 'pointer-events-none border-outline-variant/10 text-on-surface/40'
            }`}
            aria-disabled={!nextUrl}
          >
            <span>Next</span>
            <ChevronRight class="h-5 w-5" stroke-width={1.8} aria-hidden="true" />
          </a>
        </nav>
      )}
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
